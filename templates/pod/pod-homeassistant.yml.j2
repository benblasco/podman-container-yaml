# Run via: podman kube play --userns=keep-id --network=host pod-homeassistant.yml
# HOMEASSISTANT_TOKEN: set homeassistant_mcp_token in host_vars (see host_vars/.../homeassistant.yml.example).
#
apiVersion: v1
kind: ConfigMap
metadata:
  name: ha-mcp-env
  labels:
    io.containers.autoupdate: "registry"
data:
  HOMEASSISTANT_URL: {{ homeassistant_mcp_url | default('http://127.0.0.1:8123') | to_json }}
  HOMEASSISTANT_TOKEN: {{ homeassistant_mcp_token | to_json }}
---
apiVersion: v1
kind: Pod
metadata:
  name: homeassistant
  labels:
    io.containers.autoupdate: "registry"
spec:
  #hostUsers: false
  containers:
    - name: homeassistant
      image: ghcr.io/home-assistant/home-assistant:stable
#      ports:
#        - containerPort: 8123
#          hostPort: 8123
      volumeMounts:
        - mountPath: /config
          name: homeassistant-config
        # DBUS required for Bluetooth to work
        - mountPath: /run/dbus
          name: run-dbus
          readOnly: true
        - mountPath: /var/run/dbus
          name: var-run-dbus
        # USB Path to connect to Home Assistant ZBT-1 USB dongle
        - mountPath: /dev/ttyUSB0
          name: dev-ttyUSB0
      env:
        - name: TZ
          value: Australia/Melbourne
      securityContext:
        #allowPrivilegeEscalation: true
        capabilities:
          #drop:
            #- CAP_MKNOD
            #- CAP_NET_RAW
            #- CAP_AUDIT_WRITE
          add:
            - CAP_NET_ADMIN
            - CAP_NET_RAW
            - CAP_SYS_MODULE
        privileged: true
        #runAsUser: 1000
        #runAsGroup: 1000
        #fsGroup: 1000
        #fsGroupChangePolicy: "Always"
      livenessProbe:
        httpGet:
          path: /
          port: 8123
        initialDelaySeconds: 90
        periodSeconds: 10
        timeoutSeconds: 5
        failureThreshold: 3

    # Unofficial HA MCP server (https://github.com/homeassistant-ai/ha-mcp)
    # docker run ... -p 8086:8086 -e HOMEASSISTANT_URL=... -e HOMEASSISTANT_TOKEN=... ghcr.io/homeassistant-ai/ha-mcp:latest ha-mcp-web
    - name: ha-mcp
      image: ghcr.io/homeassistant-ai/ha-mcp:latest
      command:
        - ha-mcp-web
      # With kube quadlet Network=host, the process binds 8086 on the host; hostPort is omitted.
      # MCP HTTP transport is at /mcp (root / returns 404). Client URL: http://<host>:8086/mcp
      ports:
        - containerPort: 8086
      envFrom:
        - configMapRef:
            name: ha-mcp-env
      securityContext:
        privileged: false

  volumes:
    - name: homeassistant-config
      persistentVolumeClaim:
        claimName: homeassistant-config
    - name: run-dbus
      hostPath:
        path: /run/dbus
        readOnly: true
    - name: var-run-dbus
      hostPath:
        path: /var/run/dbus
    # USB Path to connect to Home Assistant ZBT-1 USB dongle
    - name: dev-ttyUSB0
      hostPath:
        path: /dev/ttyUSB0
        # Note: setting this explicitly as CharDevice ensured everything worked smoothly
        type: CharDevice
