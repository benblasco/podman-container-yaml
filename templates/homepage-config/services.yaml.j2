---
# Homepage services config
# https://gethomepage.dev/widgets/services/pihole/
# https://gethomepage.dev/widgets/services/unifi-controller/
# https://gethomepage.dev/widgets/services/tailscale/
- Network:
    - PiHole (micro.lan):
        icon: pi-hole.png
        href: http://micro.lan/admin
        description: PiHole on micro.lan
        widget:
          type: pihole
          url: http://micro.lan
          version: 6
          key: "{{ pihole_key }}"
    - PiHole (opti.lan):
        icon: pi-hole.png
        href: http://opti.lan/admin
        description: PiHole on opti.lan
        widget:
          type: pihole
          url: http://opti.lan
          version: 6
          key: "{{ pihole_key }}"
    - PiHole (nuc.lan):
        icon: pi-hole.png
        href: http://nuc.lan/admin
        description: PiHole on nuc.lan
        widget:
          type: pihole
          url: http://nuc.lan
          version: 6
          key: "{{ pihole_key }}"
    - Tailscale:
        icon: tailscale.png
        href: https://login.tailscale.com
        description: Tailscale VPN
        widget:
          type: tailscale
          deviceid: {{ tailscale_deviceid }}  # found on Tailscale dashboard machine overview page
          key: "{{ homepage_tailscale_key }}"
    - Unifi Controller:
        icon: unifi.png
        href: https://micro.lan:8443
        description: Unifi Controller on micro.lan
        widget:
          type: unifi
          url: https://micro.lan:8443
          username: "{{ unifi_local_user }}"
          password: "{{ unifi_local_password }}"
          site: "{{ unifi_site }}"
    - EdgeRouter 10X:
        icon: ubiquiti.png
        href: https://192.168.1.1/
        description: Ubiquiti EdgeRouter 10X
    - D-Link DGS-1100-08P switch:
        icon: mdi-switch
        href: http://dlink.lan/
        description: D-Link managed switch

# https://gethomepage.dev/widgets/services/transmission/
# https://gethomepage.dev/widgets/services/sonarr/
# https://gethomepage.dev/widgets/services/radarr/
# https://gethomepage.dev/widgets/services/lidarr/
# https://gethomepage.dev/widgets/services/prowlarr/
- Downloads:
    - Transmission:
        icon: transmission.png
        href: http://micro.lan:9091/transmission/web/
        description: Transmission on micro.lan
        widget:
          type: transmission
          url: http://micro.lan:9091
          rpcUrl: /transmission/
          # username: <optional>
          # password: <optional>
    - Sonarr (TV):
        icon: sonarr.png
        href: http://micro.lan:8989
        description: Sonarr on micro.lan
        widget:
          type: sonarr
          url: http://micro.lan:8989
          key: "{{ sonarr_api_key }}"
    - Radarr (Movies):
        icon: radarr.png
        href: http://micro.lan:7878
        description: Radarr on micro.lan
        widget:
          type: radarr
          url: http://micro.lan:7878
          key: "{{ radarr_api_key }}"
    - Lidarr (Music):
        icon: lidarr.png
        href: http://micro.lan:8686
        description: Lidarr on micro.lan
        widget:
          type: lidarr
          url: http://micro.lan:8686
          key: "{{ lidarr_api_key }}"
    - Prowlarr (Indexers):
        icon: prowlarr.png
        href: http://micro.lan:9696
        description: Prowlarr on micro.lan
        widget:
          type: prowlarr
          url: http://micro.lan:9696
          key: "{{ prowlarr_api_key }}"

# https://gethomepage.dev/widgets/services/uptime-kuma/
# https://gethomepage.dev/widgets/services/netalertx/
# https://gethomepage.dev/widgets/services/homeassistant/
# https://gethomepage.dev/widgets/services/esphome/
- Infrastructure:
    - Uptime Kuma:
        icon: uptime-kuma.png
        href: http://micro.lan:3001/dashboard
        description: Uptime Kuma on micro.lan
        widget:
          type: uptimekuma
          url: http://micro.lan:3001
          slug: "{{ uptime_kuma_status_slug }}"
    - Jenkins:
        icon: jenkins.png
        href: http://micro.lan:18080
        description: Jenkins on micro.lan
    - Docker Registry UI (micro.lan):
        icon: docker.png
        href: http://micro.lan:8000
        description: Docker Registry UI on micro.lan
    - Docker Registry UI (nuc.lan):
        icon: docker.png
        href: http://nuc.lan:8000
        description: Docker Registry UI on nuc.lan
    # NetAlertX + Homepage: with a UI password enabled, the API returns HTML login unless
    # the request carries a Bearer token. Set the token in NetAlertX (API / SYNC settings)
    # and the same value in host_vars/.../homepage.yml as homepage_netalertx_api_token.
    # Empty or wrong token → JSON.parse errors in the widget. version: 2 for NetAlertX >= 26.1.17.
    # Note that the port for the API is the graphql port as described below:
    # https://github.com/netalertx/NetAlertX/blob/main/docs/API.md
    - NetAlertX:
        icon: netalertx.png
        href: http://micro.lan:20211
        description: NetAlertX on micro.lan
        widget:
          type: netalertx
          url: http://micro.lan:20212
          key: "{{ homepage_netalertx_api_token }}"
          version: 2
    - Home Assistant:
        icon: home-assistant.png
        href: http://micro.lan:8123
        description: Home Assistant on micro.lan
        widget:
          type: homeassistant
          url: http://micro.lan:8123
          key: "{{ homeassistant_long_lived_token }}"
    - ESPHome:
        icon: esphome.png
        href: http://micro.lan:6052
        description: ESPHome on micro.lan
        widget:
          type: esphome
          url: http://micro.lan:6052
{% if esphome_username | default('') | length > 0 %}
          username: "{{ esphome_username }}"
          password: "{{ esphome_password }}"
{% endif %}
    - HashiCorp Vault:
        icon: vault.png
        href: http://micro.lan:8200/ui/
        description: Vault on micro.lan
    - Signal API:
        icon: signal.png
        href: http://micro.lan:9922/v1/
        description: Signal Messenger REST API on micro.lan

- Servers:
    - Cockpit (micro.lan):
        icon: cockpit.png
        href: https://micro.lan:9090/
        description: Cockpit on micro.lan
    - Cockpit (nuc.lan):
        icon: cockpit.png
        href: https://nuc.lan:9090/
        description: Cockpit on nuc.lan
    - Cockpit (opti.lan):
        icon: cockpit.png
        href: https://opti.lan:9090/
        description: Cockpit on opti.lan
    - Cockpit (hex.lan):
        icon: cockpit.png
        href: https://hex.lan:9090/
        description: Cockpit on hex.lan
