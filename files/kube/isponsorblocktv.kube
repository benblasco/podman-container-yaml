[Unit]
Description=iSponsorBlockTV container run by Podman
# Source: https://github.com/dmunozv04/iSponsorBlockTV
Before=local-fs.target
After=network.target
# Limit restart attempts to avoid cyclic restarts
StartLimitBurst=3
StartLimitIntervalSec=300

[Kube]
Yaml=pod-isponsorblocktv.yml

[Service]
# Recover from sd_notify race condition during boot storm
Restart=on-failure
RestartSec=15

[Install]
# Start by default on boot
WantedBy=multi-user.target default.target
