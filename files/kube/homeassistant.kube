[Unit]
Description=Home Assistant container run by Podman
After=network.target
# Boot stagger: Tier 1
RandomizedDelaySec=60s
# Limit restart attempts to avoid cyclic restarts
StartLimitBurst=5
StartLimitIntervalSec=300

[Kube]
Yaml=pod-homeassistant.yml
#UserNS=keep-id
Network=host

[Service]
# Recover from sd_notify race condition during boot storm
Restart=on-failure
RestartSec=15
TimeoutStartSec=300

[Install]
# Start by default on boot
WantedBy=multi-user.target default.target
