[Unit]
Description=Ubiquiti Unifi controller container run by Podman
#Before=local-fs.target
After=network-online.target
# Boot stagger: Tier 1
RandomizedDelaySec=60s
# Limit restart attempts to avoid cyclic restarts
StartLimitBurst=5
StartLimitIntervalSec=300

[Kube]
Yaml=pod-unifi.yml

[Service]
# Recover from sd_notify race condition during boot storm
Restart=on-failure
RestartSec=15
TimeoutStartSec=600

[Install]
# Start by default on boot
WantedBy=multi-user.target default.target
