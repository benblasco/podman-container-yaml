[Unit]
Description=BentoPDF container run by Podman
After=network-online.target
# Limit restart attempts to avoid cyclic restarts
StartLimitBurst=3
StartLimitIntervalSec=300

[Kube]
Yaml=pod-bentopdf.yml

[Service]
# Recover from sd_notify race condition during boot storm
Restart=on-failure
RestartSec=15

[Install]
# Start by default on boot
WantedBy=multi-user.target default.target
